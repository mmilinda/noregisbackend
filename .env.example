# ================================
# BASE DE DONNÉES (MongoDB)
# ================================
# Pour une instance locale MongoDB
MONGODB_URI=mongodb://localhost:27017/registre_visiteurs

# Pour MongoDB Atlas (cloud)
# MONGODB_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/<database>?retryWrites=true&w=majority

# ================================
# SÉCURITÉ
# ================================
JWT_SECRET=change_ce_secret_en_production_svp
JWT_EXPIRES_IN=8h

# ================================
# SERVEUR
# ================================
PORT=3000
NODE_ENV=development

# ================================
# UPLOADS
# ================================
MAX_FILE_SIZE=5242880
UPLOAD_DIR=uploads
