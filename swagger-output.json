{
  "swagger": "2.0",
  "info": {
    "title": "Registre Visiteurs API",
    "description": "Documentation de l'API de gestion des visiteurs",
    "version": "1.0.0"
  },
  "host": "noregisbackend.onrender.com",
  "basePath": "/",
  "schemes": ["https"],
  "securityDefinitions": {
    "BearerAuth": {
      "type": "apiKey",
      "in": "header",
      "name": "Authorization",
      "description": "Entrez : Bearer <votre_token_jwt>"
    }
  },
  "paths": {

    "/api/auth/login": {
      "post": {
        "tags": ["Auth"],
        "summary": "Connexion utilisateur",
        "parameters": [
          {
            "name": "body",
            "in": "body",
            "required": true,
            "schema": { "$ref": "#/definitions/LoginInput" }
          }
        ],
        "responses": {
          "200": { "description": "Connexion réussie", "schema": { "$ref": "#/definitions/LoginResponse" } },
          "400": { "description": "Données invalides" },
          "401": { "description": "Identifiants incorrects" },
          "500": { "description": "Erreur serveur" }
        }
      }
    },

    "/api/auth/register": {
      "post": {
        "tags": ["Auth"],
        "summary": "Inscription d'un nouvel utilisateur",
        "parameters": [
          {
            "name": "body",
            "in": "body",
            "required": true,
            "schema": { "$ref": "#/definitions/RegisterInput" }
          }
        ],
        "responses": {
          "201": { "description": "Utilisateur créé", "schema": { "$ref": "#/definitions/UtilisateurResponse" } },
          "400": { "description": "Données invalides" },
          "409": { "description": "Email déjà utilisé" },
          "500": { "description": "Erreur serveur" }
        }
      }
    },

    "/api/auth/profil": {
      "get": {
        "tags": ["Auth"],
        "summary": "Récupérer le profil de l'utilisateur connecté",
        "security": [{ "BearerAuth": [] }],
        "responses": {
          "200": { "description": "Profil récupéré", "schema": { "$ref": "#/definitions/UtilisateurResponse" } },
          "401": { "description": "Non authentifié" },
          "500": { "description": "Erreur serveur" }
        }
      }
    },

    "/api/visiteurs": {
      "get": {
        "tags": ["Visiteurs"],
        "summary": "Lister tous les visiteurs",
        "security": [{ "BearerAuth": [] }],
        "responses": {
          "200": {
            "description": "Liste des visiteurs",
            "schema": {
              "type": "object",
              "properties": {
                "success": { "type": "boolean", "example": true },
                "visiteurs": { "type": "array", "items": { "$ref": "#/definitions/Visiteur" } }
              }
            }
          },
          "401": { "description": "Non authentifié" },
          "500": { "description": "Erreur serveur" }
        }
      },
      "post": {
        "tags": ["Visiteurs"],
        "summary": "Créer un nouveau visiteur",
        "security": [{ "BearerAuth": [] }],
        "parameters": [
          {
            "name": "body",
            "in": "body",
            "required": true,
            "schema": { "$ref": "#/definitions/VisiteurInput" }
          }
        ],
        "responses": {
          "201": { "description": "Visiteur créé", "schema": { "$ref": "#/definitions/Visiteur" } },
          "400": { "description": "Données invalides" },
          "401": { "description": "Non authentifié" },
          "500": { "description": "Erreur serveur" }
        }
      }
    },

    "/api/visiteurs/{id}": {
      "get": {
        "tags": ["Visiteurs"],
        "summary": "Récupérer un visiteur par ID",
        "security": [{ "BearerAuth": [] }],
        "parameters": [
          { "name": "id", "in": "path", "required": true, "type": "string", "example": "664f1a2b3c4d5e6f7a8b9c0d" }
        ],
        "responses": {
          "200": { "description": "Visiteur trouvé", "schema": { "$ref": "#/definitions/Visiteur" } },
          "401": { "description": "Non authentifié" },
          "404": { "description": "Visiteur non trouvé" },
          "500": { "description": "Erreur serveur" }
        }
      },
      "put": {
        "tags": ["Visiteurs"],
        "summary": "Modifier un visiteur",
        "security": [{ "BearerAuth": [] }],
        "parameters": [
          { "name": "id", "in": "path", "required": true, "type": "string", "example": "664f1a2b3c4d5e6f7a8b9c0d" },
          { "name": "body", "in": "body", "required": true, "schema": { "$ref": "#/definitions/VisiteurInput" } }
        ],
        "responses": {
          "200": { "description": "Visiteur modifié", "schema": { "$ref": "#/definitions/Visiteur" } },
          "401": { "description": "Non authentifié" },
          "404": { "description": "Visiteur non trouvé" },
          "500": { "description": "Erreur serveur" }
        }
      }
    },

    "/api/visites": {
      "get": {
        "tags": ["Visites"],
        "summary": "Lister toutes les visites",
        "security": [{ "BearerAuth": [] }],
        "responses": {
          "200": {
            "description": "Liste des visites",
            "schema": {
              "type": "object",
              "properties": {
                "success": { "type": "boolean", "example": true },
                "visites": { "type": "array", "items": { "$ref": "#/definitions/Visite" } }
              }
            }
          },
          "401": { "description": "Non authentifié" },
          "500": { "description": "Erreur serveur" }
        }
      }
    },

    "/api/visites/en-cours": {
      "get": {
        "tags": ["Visites"],
        "summary": "Lister les visites en cours",
        "security": [{ "BearerAuth": [] }],
        "responses": {
          "200": {
            "description": "Visites en cours",
            "schema": {
              "type": "object",
              "properties": {
                "success": { "type": "boolean", "example": true },
                "visites": { "type": "array", "items": { "$ref": "#/definitions/Visite" } }
              }
            }
          },
          "401": { "description": "Non authentifié" },
          "500": { "description": "Erreur serveur" }
        }
      }
    },

    "/api/visites/entree": {
      "post": {
        "tags": ["Visites"],
        "summary": "Enregistrer l'entrée d'un visiteur",
        "security": [{ "BearerAuth": [] }],
        "parameters": [
          { "name": "body", "in": "body", "required": true, "schema": { "$ref": "#/definitions/EntreeInput" } }
        ],
        "responses": {
          "201": { "description": "Entrée enregistrée", "schema": { "$ref": "#/definitions/Visite" } },
          "400": { "description": "Données invalides" },
          "401": { "description": "Non authentifié" },
          "404": { "description": "Visiteur non trouvé" },
          "409": { "description": "Visite déjà en cours" },
          "500": { "description": "Erreur serveur" }
        }
      }
    },

    "/api/visites/sortie/{id}": {
      "post": {
        "tags": ["Visites"],
        "summary": "Enregistrer la sortie d'un visiteur",
        "security": [{ "BearerAuth": [] }],
        "parameters": [
          { "name": "id", "in": "path", "required": true, "type": "string", "description": "ID de la visite", "example": "664f1a2b3c4d5e6f7a8b9c0e" }
        ],
        "responses": {
          "200": { "description": "Sortie enregistrée", "schema": { "$ref": "#/definitions/Visite" } },
          "400": { "description": "Visite déjà terminée" },
          "401": { "description": "Non authentifié" },
          "404": { "description": "Visite non trouvée" },
          "500": { "description": "Erreur serveur" }
        }
      }
    },

    "/api/scan": {
      "post": {
        "tags": ["Scan"],
        "summary": "Scanner une image de pièce d'identité (OCR)",
        "security": [{ "BearerAuth": [] }],
        "consumes": ["multipart/form-data"],
        "parameters": [
          { "name": "image", "in": "formData", "required": true, "type": "file", "description": "Fichier image (JPG, PNG)" }
        ],
        "responses": {
          "200": {
            "description": "Texte extrait",
            "schema": {
              "type": "object",
              "properties": {
                "success": { "type": "boolean", "example": true },
                "texte": { "type": "string", "example": "NOM: DUPONT\nPRENOM: JEAN" }
              }
            }
          },
          "400": { "description": "Aucune image fournie" },
          "401": { "description": "Non authentifié" },
          "500": { "description": "Erreur serveur" }
        }
      }
    },

    "/api/search": {
      "get": {
        "tags": ["Recherche"],
        "summary": "Rechercher des visiteurs et leurs visites",
        "security": [{ "BearerAuth": [] }],
        "parameters": [
          { "name": "query", "in": "query", "type": "string", "description": "Nom, prénom ou numéro de pièce", "example": "Dupont" },
          { "name": "statut", "in": "query", "type": "string", "enum": ["EN_COURS", "TERMINE", "ANNULE"], "description": "Statut de la visite" },
          { "name": "dateDebut", "in": "query", "type": "string", "format": "date", "description": "Date de début (YYYY-MM-DD)", "example": "2024-01-01" },
          { "name": "dateFin", "in": "query", "type": "string", "format": "date", "description": "Date de fin (YYYY-MM-DD)", "example": "2024-12-31" }
        ],
        "responses": {
          "200": {
            "description": "Résultats de la recherche",
            "schema": {
              "type": "object",
              "properties": {
                "success": { "type": "boolean", "example": true },
                "total": { "type": "integer", "example": 3 },
                "resultats": { "type": "array", "items": { "$ref": "#/definitions/ResultatRecherche" } }
              }
            }
          },
          "400": { "description": "Paramètre de recherche requis" },
          "401": { "description": "Non authentifié" },
          "500": { "description": "Erreur serveur" }
        }
      }
    }
  },

  "definitions": {
    "LoginInput": {
      "type": "object",
      "required": ["email", "motDePasse"],
      "properties": {
        "email": { "type": "string", "example": "admin@example.com" },
        "motDePasse": { "type": "string", "example": "motdepasse123" }
      }
    },
    "RegisterInput": {
      "type": "object",
      "required": ["nom", "email", "motDePasse"],
      "properties": {
        "nom": { "type": "string", "example": "Jean Dupont" },
        "email": { "type": "string", "example": "jean@example.com" },
        "motDePasse": { "type": "string", "example": "motdepasse123" },
        "role": { "type": "string", "enum": ["AGENT", "ADMIN"], "example": "AGENT" }
      }
    },
    "LoginResponse": {
      "type": "object",
      "properties": {
        "success": { "type": "boolean", "example": true },
        "token": { "type": "string", "example": "eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9..." },
        "utilisateur": { "$ref": "#/definitions/Utilisateur" }
      }
    },
    "UtilisateurResponse": {
      "type": "object",
      "properties": {
        "success": { "type": "boolean", "example": true },
        "utilisateur": { "$ref": "#/definitions/Utilisateur" }
      }
    },
    "Utilisateur": {
      "type": "object",
      "properties": {
        "_id": { "type": "string", "example": "664f1a2b3c4d5e6f7a8b9c0f" },
        "nom": { "type": "string", "example": "Admin" },
        "email": { "type": "string", "example": "admin@example.com" },
        "role": { "type": "string", "enum": ["AGENT", "ADMIN"], "example": "ADMIN" },
        "isActif": { "type": "boolean", "example": true }
      }
    },
    "VisiteurInput": {
      "type": "object",
      "required": ["nom", "prenom", "numeroPiece"],
      "properties": {
        "nom": { "type": "string", "example": "Dupont" },
        "prenom": { "type": "string", "example": "Jean" },
        "dateNaissance": { "type": "string", "example": "1990-05-15" },
        "numeroPiece": { "type": "string", "example": "CNI123456" },
        "typePiece": { "type": "string", "enum": ["CNI", "PASSEPORT", "PERMIS", "CARTE_SEJOUR"], "example": "CNI" }
      }
    },
    "Visiteur": {
      "type": "object",
      "properties": {
        "_id": { "type": "string", "example": "664f1a2b3c4d5e6f7a8b9c0d" },
        "nom": { "type": "string", "example": "Dupont" },
        "prenom": { "type": "string", "example": "Jean" },
        "dateNaissance": { "type": "string", "example": "1990-05-15" },
        "numeroPiece": { "type": "string", "example": "CNI123456" },
        "typePiece": { "type": "string", "enum": ["CNI", "PASSEPORT", "PERMIS", "CARTE_SEJOUR"], "example": "CNI" },
        "createdAt": { "type": "string", "example": "2024-01-01T00:00:00.000Z" },
        "updatedAt": { "type": "string", "example": "2024-01-01T00:00:00.000Z" }
      }
    },
    "EntreeInput": {
      "type": "object",
      "required": ["visiteurId", "personneVisitee", "service"],
      "properties": {
        "visiteurId": { "type": "string", "example": "664f1a2b3c4d5e6f7a8b9c0d" },
        "personneVisitee": { "type": "string", "example": "Mme Koné" },
        "service": { "type": "string", "example": "Ressources Humaines" },
        "motif": { "type": "string", "example": "Entretien d'embauche" }
      }
    },
    "Visite": {
      "type": "object",
      "properties": {
        "_id": { "type": "string", "example": "664f1a2b3c4d5e6f7a8b9c0e" },
        "visiteurId": { "type": "string", "example": "664f1a2b3c4d5e6f7a8b9c0d" },
        "personneVisitee": { "type": "string", "example": "Mme Koné" },
        "service": { "type": "string", "example": "Ressources Humaines" },
        "heureEntree": { "type": "string", "example": "2024-01-01T08:00:00.000Z" },
        "heureSortie": { "type": "string", "example": null },
        "statut": { "type": "string", "enum": ["EN_COURS", "TERMINE", "ANNULE"], "example": "EN_COURS" },
        "motif": { "type": "string", "example": "Entretien d'embauche" },
        "createdAt": { "type": "string", "example": "2024-01-01T00:00:00.000Z" }
      }
    },
    "ResultatRecherche": {
      "type": "object",
      "properties": {
        "_id": { "type": "string", "example": "664f1a2b3c4d5e6f7a8b9c0d" },
        "nom": { "type": "string", "example": "Dupont" },
        "prenom": { "type": "string", "example": "Jean" },
        "numeroPiece": { "type": "string", "example": "CNI123456" },
        "typePiece": { "type": "string", "example": "CNI" },
        "visites": { "type": "array", "items": { "$ref": "#/definitions/Visite" } }
      }
    },
    "ErrorResponse": {
      "type": "object",
      "properties": {
        "success": { "type": "boolean", "example": false },
        "message": { "type": "string", "example": "Une erreur est survenue" }
      }
    }
  }
}